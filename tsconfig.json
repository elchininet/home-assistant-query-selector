{
  "compilerOptions": {
    "outDir": "./dist/",
    "module": "esnext",
    "target": "es6",
    "lib": ["dom", "es2017"],
    "types": ["node"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noImplicitAny": true,
    "removeComments": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "paths": {
      "@types": ["./src/@types"],
      "@constants": ["./src/constants"],
      "@selectors": ["./src/selectors"],
      "@utilities": ["./src/utilities"],
      "@lib": ["./src/lib"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}